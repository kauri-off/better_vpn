# Better VPN backend environment. Copy to /etc/better_vpn/panel.env and edit.

# SQLite database file path (required). Created automatically on first run.
DATABASE_URL=/var/lib/better_vpn/panel.db

# Optional: log level (info, debug, warn). Read at startup, before the database
# is opened, so this stays an environment variable rather than a DB setting.
RUST_LOG=info
