# Better VPN backend environment. Copy to /etc/better_vpn/panel.env and edit.

# Postgres connection (required).
DATABASE_URL=postgres://better_vpn:CHANGE_ME@127.0.0.1/better_vpn

# Management gRPC/gRPC-Web API (fronted by Caddy). Keep on localhost.
GRPC_ADDR=127.0.0.1:50051

# Hysteria HTTP auth backend listener. Must match auth.http.url in config.yaml.
AUTH_ADDR=127.0.0.1:8080

# Long random string used to sign admin sessions. Generate with:
#   openssl rand -base64 48
JWT_SECRET=CHANGE_ME_LONG_RANDOM

# Optional: systemd unit restarted by the panel's "Restart core" button.
# Requires installing deploy/polkit-better-vpn.rules so the unprivileged
# better_vpn user may restart it; if you change this, update that rule's unit.
CORE_SERVICE=hysteria.service

# Optional: path to the Hysteria core binary. The panel reads its version from
# this and replaces it on "Update core". Must be in a directory writable by the
# better_vpn user. Defaults to the path below.
#CORE_BIN=/var/lib/better_vpn/bin/hysteria

# Optional: log level (info, debug, warn).
RUST_LOG=info
